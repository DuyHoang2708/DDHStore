@model IEnumerable<DDHSTORE.Models.Category>
@{
    ViewData["Title"] = "Danh sách danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- Page Header -->
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Danh mục</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-0 text-gradient">Quản lý danh mục</h2>
        <p class="text-muted mb-0">Tổng cộng @Model.Count() danh mục</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm hover-lift">
        <i class="fa-solid fa-plus me-2"></i> Thêm danh mục mới
    </a>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <div class="d-flex align-items-center">
            <div class="alert-icon bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                <i class="fa-solid fa-check"></i>
            </div>
            <div>
                <h6 class="alert-heading mb-1">Thành công!</h6>
                <p class="mb-0">@TempData["Success"]</p>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card bg-white rounded-4 p-4 shadow-sm border-start border-4 border-primary">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Tổng danh mục</p>
                    <h3 class="fw-bold mb-0 text-primary">@Model.Count()</h3>
                </div>
                <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                    <i class="fa-solid fa-layer-group fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card bg-white rounded-4 p-4 shadow-sm border-start border-4 border-success">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Đang hiển thị</p>
                    <h3 class="fw-bold mb-0 text-success">@Model.Count(c => c.Status == 1)</h3>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
                    <i class="fa-solid fa-eye fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card bg-white rounded-4 p-4 shadow-sm border-start border-4 border-secondary">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Đang ẩn</p>
                    <h3 class="fw-bold mb-0 text-secondary">@Model.Count(c => c.Status != 1)</h3>
                </div>
                <div class="stat-icon bg-secondary bg-opacity-10 text-secondary rounded-3 p-3">
                    <i class="fa-solid fa-eye-slash fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Card -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-bottom py-3 px-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="fa-solid fa-list me-2 text-primary"></i>Danh sách danh mục
                </h5>
            </div>
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="fa-solid fa-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control border-start-0 bg-light" id="searchInput" 
                           placeholder="Tìm kiếm danh mục..." onkeyup="filterTable()">
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="categoryTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 100px;">
                            <i class="fa-solid fa-hashtag me-1"></i>ID
                        </th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">
                            <i class="fa-solid fa-tag me-1"></i>Tên danh mục
                        </th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center" style="width: 150px;">
                            <i class="fa-solid fa-circle-dot me-1"></i>Trạng thái
                        </th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-muted text-end" style="width: 300px;">
                            <i class="fa-solid fa-cogs me-1"></i>Hành động
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom border-light">
                            <td class="ps-4 py-3">
                                <span class="badge bg-light text-dark fw-bold rounded-pill px-3 py-2">
                                    #@item.CategoryId.ToString("D3")
                                </span>
                            </td>
                            <td class="py-3">
                                <div class="d-flex align-items-center">
                                    <div class="category-icon bg-primary bg-opacity-10 text-primary rounded-3 me-3 d-flex align-items-center justify-content-center" 
                                         style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-folder-open"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">@item.CategoryName</h6>
                                        <small class="text-muted">Danh mục sản phẩm</small>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3 text-center">
                                @if (item.Status == 1)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-circle-check me-1"></i>Hiển thị
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-circle-minus me-1"></i>Đã ẩn
                                    </span>
                                }
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.CategoryId" 
                                       class="btn btn-outline-warning btn-sm rounded-start-3 hover-scale" 
                                       data-bs-toggle="tooltip" title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    
                                    <a asp-action="ToggleStatus" asp-route-id="@item.CategoryId" 
                                       class="btn btn-sm @(item.Status == 1 ? "btn-outline-secondary" : "btn-outline-success") hover-scale"
                                       data-bs-toggle="tooltip" 
                                       title="@(item.Status == 1 ? "Ẩn danh mục" : "Hiển thị danh mục")">
                                        <i class="fa-solid @(item.Status == 1 ? "fa-eye-slash" : "fa-eye")"></i>
                                    </a>
                                    
                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-end-3 hover-scale" 
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@item.CategoryId"
                                            title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        
                        <!-- Delete Modal -->
                        <div class="modal fade" id="deleteModal-@item.CategoryId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow">
                                    <div class="modal-header border-0 pb-0">
                                        <h5 class="modal-title fw-bold text-danger">
                                            <i class="fa-solid fa-triangle-exclamation me-2"></i>Xác nhận xóa
                                        </h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center py-4">
                                        <div class="mb-3">
                                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                                                 style="width: 80px; height: 80px;">
                                                <i class="fa-solid fa-trash-can fa-2x"></i>
                                            </div>
                                            <p class="mb-1">Bạn có chắc chắn muốn xóa danh mục?</p>
                                            <h5 class="fw-bold text-dark mb-0">"@item.CategoryName"</h5>
                                        </div>
                                        <p class="text-muted small mb-0">Hành động này không thể hoàn tác.</p>
                                    </div>
                                    <div class="modal-footer border-0 pt-0 justify-content-center">
                                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-danger rounded-pill px-4">
                                            <i class="fa-solid fa-trash me-2"></i>Xóa ngay
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="mb-3">
                    <i class="fa-solid fa-inbox fa-3x text-muted opacity-25"></i>
                </div>
                <h5 class="text-muted mb-2">Chưa có danh mục nào</h5>
                <p class="text-muted mb-3">Bắt đầu bằng cách thêm danh mục đầu tiên của bạn</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fa-solid fa-plus me-2"></i>Thêm danh mục mới
                </a>
            </div>
        }
    </div>
    
    @if (Model.Any())
    {
        <div class="card-footer bg-white border-top py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">Hiển thị @Model.Count() danh mục</small>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">Sau</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<style>
    /* Custom Styles */
    .text-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .hover-lift {
        transition: all 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
    
    .hover-scale {
        transition: all 0.2s ease;
    }
    .hover-scale:hover {
        transform: scale(1.05);
    }
    
    .stat-card {
        transition: all 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }
    
    .table tbody tr {
        transition: all 0.2s ease;
    }
    .table tbody tr:hover {
        background-color: #f8f9fa;
        transform: scale(1.002);
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    
    .category-icon {
        transition: all 0.3s ease;
    }
    tr:hover .category-icon {
        transform: rotate(5deg) scale(1.1);
    }
    
    .btn-group .btn {
        border-width: 1.5px;
    }
    
    .rounded-4 {
        border-radius: 1rem !important;
    }
    
    .alert-icon {
        animation: pulse 2s infinite;
    }
    
    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(25, 135, 84, 0); }
        100% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0); }
    }
    
    /* Empty state animation */
    .fa-inbox {
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
</style>

@section Scripts {
    <script>
        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
        
        // Search functionality
        function filterTable() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("categoryTable");
            tr = table.getElementsByTagName("tr");
            
            for (i = 1; i < tr.length; i++) {
                td = tr[i].getElementsByTagName("td")[1];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }       
            }
        }
        
        // Auto-hide alert after 5 seconds
        setTimeout(function() {
            var alert = document.querySelector('.alert');
            if (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        }, 5000);
    </script>
}