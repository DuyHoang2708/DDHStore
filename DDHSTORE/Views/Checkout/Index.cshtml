@model DDHSTORE.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán an toàn";
}

<!-- Use Inter for a super modern, clean typography look -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<!-- Select2 for modern searchable dropdowns -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<style>
    :root {
        --brand-main: #000000;
        --brand-accent: #6366f1;
        --bg-color: #f8fafc;
        --card-bg: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #f1f5f9;
        --input-bg: #f8fafc;
        --radius-lg: 20px;
        --radius-xl: 30px;
    }

    body {
        background-color: var(--bg-color);
        font-family: 'Inter', sans-serif;
        color: var(--text-primary);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    .checkout-wrapper {
        max-width: 1100px;
        margin: 40px auto 100px;
        padding: 0 20px;
    }

    .page-title {
        font-weight: 900;
        font-size: 2.75rem;
        letter-spacing: -0.05em;
        margin-bottom: 40px;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 50px;
    }

    /* Cards */
    .premium-card {
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        padding: 35px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
        border: 1px solid #fff;
        margin-bottom: 24px;
        position: relative;
    }

    .card-label {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--brand-accent);
        margin-bottom: 15px;
        display: block;
    }

    .card-title {
        font-size: 1.65rem;
        font-weight: 800;
        margin-bottom: 30px;
        letter-spacing: -0.02em;
    }

    /* Address Selection */
    .address-box {
        border: 2px solid var(--border-color);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 16px;
        cursor: pointer;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .address-box:hover {
        border-color: #cbd5e1;
        background: #fdfdfd;
    }

    .address-box.active {
        border-color: var(--brand-accent);
        background: #f5f3ff;
        transform: translateY(-2px);
    }

    .address-radio {
        position: absolute;
        top: 25px;
        right: 25px;
        accent-color: var(--brand-accent);
        width: 18px;
        height: 18px;
    }

    /* Action Button for New Address */
    .btn-add-address {
        background: #fff;
        border: 2px solid var(--brand-accent);
        color: var(--brand-accent);
        border-radius: 12px;
        padding: 16px 24px;
        font-weight: 700;
        font-size: 1rem;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.2s;
        margin-bottom: 20px;
    }

    .btn-add-address:hover {
        background: var(--brand-accent);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }

    /* Form Styling */
    .modern-form-group {
        margin-bottom: 20px;
    }

    .modern-form-label {
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
        display: block;
    }

    .modern-input {
        background: var(--input-bg);
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 14px 18px;
        width: 100%;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-weight: 600;
    }

    .modern-input:focus {
        border-color: var(--brand-accent);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    /* Sidebar Sticky */
    .summary-column {
        position: sticky;
        top: 40px;
        height: fit-content;
    }

    .product-hero {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
    }

    .product-img-frame {
        width: 100px;
        height: 100px;
        background: #fff;
        border: 1px solid #f1f5f9;
        border-radius: 20px;
        padding: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .product-img-frame img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .product-meta h3 {
        font-weight: 800;
        font-size: 1.15rem;
        margin: 0;
    }

    /* Qty Stepper */
    .qty-stepper {
        display: flex;
        background: #f1f5f9;
        border-radius: 12px;
        padding: 4px;
        margin-top: 15px;
        width: fit-content;
    }

    .step-btn {
        width: 32px;
        height: 32px;
        border: none;
        background: transparent;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .step-btn:hover { background: #e2e8f0; }

    .qty-input {
        width: 44px;
        border: none;
        background: transparent;
        text-align: center;
        font-weight: 800;
        font-size: 1rem;
    }

    /* Calculations */
    .calc-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-weight: 500;
        color: var(--text-secondary);
    }

    .calc-total {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        font-weight: 900;
        font-size: 1.75rem;
        color: var(--brand-main);
    }

    /* Complete Button */
    .btn-complete-luxury {
        width: 100%;
        background: var(--brand-main);
        color: #fff;
        padding: 22px;
        border-radius: 18px;
        font-weight: 800;
        font-size: 1.15rem;
        border: none;
        margin-top: 40px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .btn-complete-luxury:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        opacity: 0.95;
        color: #fff;
    }

    /* Administrative Reveal */
    .new-address-wrapper {
        border-top: 1px dashed #e2e8f0;
        margin-top: 25px;
        padding-top: 25px;
        display: none;
    }

    /* Select2 Skin */
    .select2-container--bootstrap-5 .select2-selection {
        border-radius: 12px !important;
        border: 1px solid #e2e8f0 !important;
        padding: 12px !important;
        background: var(--input-bg) !important;
        height: auto !important;
    }

    @@media (max-width: 991px) {
        .main-grid { grid-template-columns: 1fr; }
        .summary-column { position: static; margin-top: 40px; }
    }
</style>

<div class="checkout-wrapper">
    <h1 class="page-title">Sẵn sàng trải nghiệm.</h1>

    <div class="main-grid">
        <main>
            <form asp-action="Index" method="post" id="formLuxury">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="IsCartCheckout" />
                
                @if (!Model.IsCartCheckout)
                {
                    <input type="hidden" asp-for="ProductId" />
                    <input type="hidden" asp-for="Price" id="valPrice" />
                    <input type="hidden" asp-for="StockQuantity" id="valStock" />
                    <input type="hidden" asp-for="Quantity" id="hiddenQty" />
                }

                <!-- 1. Address Section -->
                <div class="premium-card">
                    <span class="card-label">BƯỚC 1</span>
                    <h2 class="card-title">Bạn nhận hàng ở đâu?</h2>

                    @if (Model.UserAddresses != null && Model.UserAddresses.Any())
                    {
                        <div class="mb-4">
                            @foreach (var addr in Model.UserAddresses)
                            {
                                <div class="address-box" data-id="@addr.AddressId" onclick="pickAddr(@addr.AddressId)">
                                    <input type="radio" name="AddressId" value="@addr.AddressId" id="ad_@addr.AddressId" class="address-radio" @(Model.UserAddresses.First() == addr ? "checked" : "") />
                                    <div class="fw-bold fs-5">@addr.RecipientName</div>
                                    <div class="text-muted small mt-1">@addr.Ward, @addr.District, @addr.Province</div>
                                    <div class="fw-bold small text-primary mt-2">@addr.Phone</div>
                                </div>
                            }
                        </div>
                    }

                    <!-- The New "Button" Trigger for Add Address -->
                    <button type="button" class="btn-add-address" onclick="toggleNewAddress()">
                        <i class="fa-solid fa-plus-circle"></i> Sử dụng địa chỉ nhận hàng khác
                    </button>
                    <!-- Hidden radio for new address state -->
                    <input type="radio" name="AddressId" value="0" id="ad_new" style="display:none" />

                    <!-- Form for new address revealed on button click -->
                    <div id="newAddressSection" class="new-address-wrapper">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="modern-form-group">
                                    <label class="modern-form-label">Tên người nhận</label>
                                    <input type="text" class="modern-input" asp-for="RecipientName" placeholder="Nguyễn Văn A" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="modern-form-group">
                                    <label class="modern-form-label">Số điện thoại</label>
                                    <input type="text" class="modern-input" asp-for="Phone" placeholder="0xxx.xxx.xxx" />
                                </div>
                            </div>
                            
                            <div class="col-12">
                                <div class="modern-form-group">
                                    <label class="modern-form-label text-indigo"><i class="fa-solid fa-map-pin me-1"></i> Tỉnh / Thành phố</label>
                                    <select id="geo_p" class="modern-input select2-lux" asp-for="Province"><option value="">Tải danh sách API...</option></select>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="modern-form-group">
                                    <label class="modern-form-label">Quận / Huyện</label>
                                    <select id="geo_d" class="modern-input select2-lux" asp-for="District"><option value="">Chọn tỉnh trước</option></select>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="modern-form-group">
                                    <label class="modern-form-label">Phường / Xã</label>
                                    <select id="geo_w" class="modern-input select2-lux" asp-for="Ward"><option value="">Chọn huyện trước</option></select>
                                </div>
                            </div>
                            
                            <div class="col-12">
                                <div class="modern-form-group">
                                    <label class="modern-form-label">Địa chỉ cụ thể</label>
                                    <input type="text" class="modern-input" asp-for="Detail" placeholder="Số nhà, ngõ, đường..." />
                                </div>
                            </div>
                            
                            <!-- Save Address Checkbox -->
                            <div class="col-12 mt-2">
                                <div class="form-check custom-check">
                                    <input class="form-check-input" type="checkbox" asp-for="SaveAddress" id="saveAddrCheck" checked>
                                    <label class="form-check-label fw-600 text-secondary" for="saveAddrCheck">
                                        Lưu địa chỉ này vào sổ địa chỉ của tôi
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Payment Section -->
                <div class="premium-card">
                    <span class="card-label">BƯỚC 2</span>
                    <h2 class="card-title">Chọn cách thanh toán.</h2>

                    <div class="d-flex flex-column gap-3">
                        <!-- COD -->
                        <div class="address-box d-flex align-items-center gap-3 p-4 active" id="pay_cash_box" onclick="pickPayment('Cash')">
                            <input type="radio" asp-for="PaymentMethod" value="Cash" checked class="form-check-input mt-0" style="accent-color: var(--brand-accent); width: 20px; height: 20px;" />
                            <div class="d-flex align-items-center gap-3 flex-grow-1">
                                <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 14px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa-solid fa-money-bill-wave text-white" style="font-size: 1.2rem;"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-5">Thanh toán khi nhận hàng (COD)</div>
                                    <div class="text-muted small">Kiểm tra hàng trước khi thanh toán cho shipper.</div>
                                </div>
                            </div>
                        </div>

                        <!-- VNPay -->
                        <div class="address-box d-flex align-items-center gap-3 p-4" id="pay_vnpay_box" onclick="pickPayment('VNPay')">
                            <input type="radio" asp-for="PaymentMethod" value="VNPay" class="form-check-input mt-0" style="accent-color: var(--brand-accent); width: 20px; height: 20px;" />
                            <div class="d-flex align-items-center gap-3 flex-grow-1">
                                <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #005baa, #003f7d); border-radius: 14px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                    <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418196384.png" alt="VNPay" style="width: 36px; height: 36px; object-fit: contain;" />
                                </div>
                                <div>
                                    <div class="fw-bold fs-5">Thanh toán qua VNPay</div>
                                    <div class="text-muted small">ATM / Visa / MasterCard / QR Pay — An toàn & nhanh chóng.</div>
                                </div>
                            </div>
                            <div class="ms-auto d-flex gap-1">
                                <span style="background: #f1f5f9; border-radius: 6px; padding: 2px 8px; font-size: 0.7rem; font-weight: 700; color: #64748b;">VISA</span>
                                <span style="background: #f1f5f9; border-radius: 6px; padding: 2px 8px; font-size: 0.7rem; font-weight: 700; color: #64748b;">MC</span>
                                <span style="background: #f1f5f9; border-radius: 6px; padding: 2px 8px; font-size: 0.7rem; font-weight: 700; color: #64748b;">QR</span>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </main>

        <!-- Sidebar Summary -->
        <aside class="summary-column">
            <div class="premium-card">
                <span class="card-label">ĐƠN HÀNG CỦA BẠN</span>
                
                @if (Model.IsCartCheckout)
                {
                     <div class="product-list" style="max-height: 400px; overflow-y: auto; margin-bottom: 20px;">
                        @foreach(var item in Model.Items)
                        {
                            <div class="product-hero mb-3 pb-3 border-bottom">
                                <div class="product-img-frame" style="width: 70px; height: 70px;">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/150" : item.ImageUrl)" alt="@item.ProductName" />
                                </div>
                                <div>
                                    <h3 style="font-size: 0.95rem;">@item.ProductName</h3>
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <span class="text-muted small">SL: @item.Quantity</span>
                                        <span class="text-indigo fw-700" style="font-size: 0.95rem;">@item.Price.ToString("N0") VNĐ</span>
                                    </div>
                                </div>
                            </div>
                        }
                     </div>
                }
                else
                {
                    <div class="product-hero">
                        <div class="product-img-frame">
                            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/150" : Model.ImageUrl)" alt="@Model.ProductName" />
                        </div>
                        <div>
                            <div class="text-muted small fw-600 mb-1">Cửa hàng DDHSTORE</div>
                            <h3 class="mb-2">@Model.ProductName</h3>
                            <div class="text-indigo fw-800">@Model.Price.ToString("N0") VNĐ</div>
                            
                            <div class="qty-stepper">
                                <button type="button" class="step-btn" onclick="modifyQty(-1)"><i class="fa-solid fa-minus"></i></button>
                                <input type="text" class="qty-input" id="qtyText" value="@Model.Quantity" readonly />
                                <button type="button" class="step-btn" onclick="modifyQty(1)"><i class="fa-solid fa-plus"></i></button>
                            </div>
                        </div>
                    </div>
                }

                <div class="pt-4 border-top">
                    <div class="calc-row">
                        <span>Giá gốc sản phẩm</span>
                        <span>@(Model.IsCartCheckout ? "Theo giỏ hàng" : Model.Price.ToString("N0") + " VNĐ")</span>
                    </div>
                    <div class="calc-row">
                        <span>Số lượng</span>
                        <span id="lb_qty">@(Model.IsCartCheckout ? Model.Items.Sum(i => i.Quantity) : Model.Quantity)</span>
                    </div>
                    <div class="calc-row text-success fw-700">
                        <span>Phí vận chuyển</span>
                        <span>MIỄN PHÍ</span>
                    </div>
                    
                    <div class="calc-total">
                        <div>TỔNG CỘNG</div>
                        <div id="lb_total">@Model.TotalAmount.ToString("N0") VNĐ</div>
                    </div>

                    <button type="button" class="btn-complete-luxury" id="btnSubmitOrder" onclick="submitFinal()">
                        <span id="btnText">ĐẶT HÀNG NGAY</span> <i class="fa-solid fa-arrow-right" id="btnIcon"></i>
                    </button>
                </div>
            </div>
        </aside>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    const isCartCheckout = @(Model.IsCartCheckout ? "true" : "false");
    const unitP = @Html.Raw(Model.IsCartCheckout ? "0" : Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture));
    const stockQuantity = @(Model.IsCartCheckout ? "0" : Model.StockQuantity.ToString());

    function formatVND(n) { return n.toLocaleString('vi-VN') + " VNĐ"; }

    function pickPayment(method) {
        // Toggle active class on payment boxes
        $('#pay_cash_box, #pay_vnpay_box').removeClass('active');
        if (method === 'Cash') {
            $('#pay_cash_box').addClass('active');
            $('input[name="PaymentMethod"][value="Cash"]').prop('checked', true);
            $('#btnText').text('ĐẶT HÀNG NGAY');
            $('#btnIcon').attr('class', 'fa-solid fa-arrow-right');
            $('#btnSubmitOrder').css('background', 'var(--brand-main)');
        } else {
            $('#pay_vnpay_box').addClass('active');
            $('input[name="PaymentMethod"][value="VNPay"]').prop('checked', true);
            $('#btnText').text('THANH TOÁN VỚI VNPAY');
            $('#btnIcon').attr('class', 'fa-solid fa-credit-card');
            $('#btnSubmitOrder').css('background', 'linear-gradient(135deg, #005baa, #003f7d)');
        }
    }

    function modifyQty(d) {
        if (isCartCheckout) return; // Không đổi sl trong checkout cart
        const ui = document.getElementById('qtyText');
        const hidden = document.getElementById('hiddenQty');
        let val = parseInt(ui.value) + d;

        if (val < 1) val = 1;
        if (val > stockQuantity) { alert('Hàng trong kho chỉ còn ' + stockQuantity); val = stockQuantity; }

        ui.value = val;
        hidden.value = val;
        
        const total = unitP * val;
        document.getElementById('lb_qty').innerText = val;
        document.getElementById('lb_total').innerText = formatVND(total);
    }

    function toggleNewAddress() {
        $('.address-box').removeClass('active');
        $('input[name="AddressId"]').prop('checked', false);
        $('#ad_new').prop('checked', true);
        
        $('#newAddressSection').slideToggle(400, function() {
            if ($(this).is(':visible')) {
                // Scroll into focus
                $('html, body').animate({ scrollTop: $(this).offset().top - 100 }, 500);
                // Refresh Select2
                $('.select2-lux').select2({ theme: 'bootstrap-5', width: '100%' });
            }
        });
    }

    function pickAddr(id) {
        $('.address-box').removeClass('active');
        $(`input[value="${id}"]`).prop('checked', true).closest('.address-box').addClass('active');
        $('#newAddressSection').slideUp();
    }

    function submitFinal() {
        // Validation for new addr
        if ($('#ad_new').is(':checked')) {
            const p = $('#geo_p').val();
            const n = $('input[name="RecipientName"]').val().trim();
            const ph = $('input[name="Phone"]').val().trim();

            if (!p || !n || !ph) {
                alert('Vui lòng hoàn thành thông tin người nhận và địa chỉ mới!');
                return;
            }
        } else if (!$('input[name="AddressId"]:checked').val()) {
            alert('Vui lòng chọn địa chỉ giao hàng!');
            return;
        }

        $('#formLuxury').submit();
    }

    $(document).ready(function() {
        $('.address-radio:checked').closest('.address-box').addClass('active');

        // Load Province API
        $.getJSON('https://provinces.open-api.vn/api/p/', function(data) {
            let h = '<option value="">Chọn Tỉnh / Thành phố</option>';
            data.forEach(p => h += `<option value="${p.name}" data-code="${p.code}">${p.name}</option>`);
            $('#geo_p').html(h).trigger('change');
        });

        $('#geo_p').on('change', function() {
            let code = $(this).find(':selected').data('code');
            $('#geo_d').html('<option value="">Tải Quận/Huyện...</option>').trigger('change');
            if (code) {
                $.getJSON(`https://provinces.open-api.vn/api/p/${code}?depth=2`, function(data) {
                    let h = '<option value="">Chọn Quận/Huyện</option>';
                    data.districts.forEach(d => h += `<option value="${d.name}" data-code="${d.code}">${d.name}</option>`);
                    $('#geo_d').html(h).trigger('change');
                });
            }
        });

        $('#geo_d').on('change', function() {
            let code = $(this).find(':selected').data('code');
            $('#geo_w').html('<option value="">Tải Phường/Xã...</option>').trigger('change');
            if (code) {
                $.getJSON(`https://provinces.open-api.vn/api/d/${code}?depth=2`, function(data) {
                    let h = '<option value="">Chọn Phường/Xã</option>';
                    data.wards.forEach(w => h += `<option value="${w.name}">${w.name}</option>`);
                    $('#geo_w').html(h).trigger('change');
                });
            }
        });
    });
</script>