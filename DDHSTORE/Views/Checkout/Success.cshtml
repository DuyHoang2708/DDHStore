@model DDHSTORE.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<!-- Use Inter for high-end typography -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --brand-success: #10b981;
        --brand-main: #0f172a;
        --bg-body: #f8fafc;
        --card-bg: #ffffff;
        --text-headline: #0f172a;
        --text-muted: #64748b;
        --radius-xl: 30px;
    }

    body {
        background-color: var(--bg-body);
        font-family: 'Inter', sans-serif;
        color: var(--text-headline);
        -webkit-font-smoothing: antialiased;
    }

    .success-wrapper {
        max-width: 700px;
        margin: 80px auto;
        padding: 0 20px;
        text-align: center;
    }

    /* Animated Checkmark */
    .checkmark-wrapper {
        width: 120px;
        height: 120px;
        background: var(--brand-success);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 40px;
        box-shadow: 0 20px 40px -10px rgba(16, 185, 129, 0.4);
        animation: scaleCheck 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleCheck {
        0% { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .checkmark-wrapper i {
        color: #fff;
        font-size: 50px;
        animation: checkBounce 0.8s 0.3s backwards;
    }

    @@keyframes checkBounce {
        0% { transform: scale(0.5); opacity: 0; }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); opacity: 1; }
    }

    .success-title {
        font-weight: 900;
        font-size: 2.5rem;
        letter-spacing: -0.05em;
        margin-bottom: 15px;
    }

    .success-msg {
        font-size: 1.15rem;
        color: var(--text-muted);
        margin-bottom: 40px;
        font-weight: 500;
    }

    /* Order Card */
    .order-card {
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        padding: 40px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
        border: 1px solid #fff;
        text-align: left;
        margin-bottom: 40px;
    }

    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 25px;
        border-bottom: 2px dashed #f1f5f9;
        margin-bottom: 25px;
    }

    .order-id {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--brand-main);
    }

    .order-date {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-weight: 600;
        font-size: 1rem;
    }

    .grand-total {
        margin-top: 25px;
        padding-top: 25px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        font-weight: 900;
        font-size: 1.5rem;
        color: var(--brand-main);
    }

    /* Action Buttons */
    .btn-group-lux {
        display: flex;
        gap: 20px;
        justify-content: center;
    }

    .btn-lux {
        padding: 18px 35px;
        border-radius: 20px;
        font-weight: 800;
        font-size: 1.05rem;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .btn-lux-primary {
        background: var(--brand-main);
        color: #fff;
        box-shadow: 0 10px 20px -5px rgba(15, 23, 42, 0.3);
    }

    .btn-lux-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -10px rgba(15, 23, 42, 0.4);
        color: #fff;
    }

    .btn-lux-outline {
        background: transparent;
        border: 2px solid #e2e8f0;
        color: var(--brand-main);
    }

    .btn-lux-outline:hover {
        background: #f1f5f9;
        transform: translateY(-3px);
    }

    /* Decorative Circle Backgrounds */
    .bg-circle {
        position: fixed;
        z-index: -1;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.05) 0%, rgba(255,255,255,0) 70%);
    }

    .circle-1 { width: 600px; height: 600px; top: -200px; left: -100px; }
    .circle-2 { width: 400px; height: 400px; bottom: -100px; right: -50px; }
</style>

<div class="bg-circle circle-1"></div>
<div class="bg-circle circle-2"></div>

<div class="success-wrapper">
    <div class="checkmark-wrapper">
        <i class="fa-solid fa-check"></i>
    </div>

    <h1 class="success-title">ĐƠN HÀNG CỦA BẠN ĐÃ ĐƯỢC TẠO THÀNH CÔNG!</h1>
    <p class="success-msg">Cảm ơn bạn đã tin tưởng chọn DDHSTORE. Chúng tôi sẽ nhanh chóng xử lý để bàn giao sản phẩm tới bạn.</p>

    <div class="order-card">
        <div class="order-header">
            <div>
                <span class="text-muted small fw-700 text-uppercase d-block mb-1">Mã đơn hàng</span>
                <span class="order-id">#ORD-@Model.OrderId</span>
            </div>
            <div class="text-end">
                <span class="text-muted small fw-700 text-uppercase d-block mb-1">Ngày đặt</span>
                <span class="order-date">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>

        <div class="order-details">
            @foreach (var detail in Model.OrderDetails)
            {
                <div class="summary-row">
                    <span class="text-muted">@detail.Product.ProductName <small>(x@detail.Quantity)</small></span>
                    <span>@((detail.Price * detail.Quantity).ToString("N0")) VNĐ</span>
                </div>
            }
            
            <div class="summary-row text-success">
                <span>Vận chuyển tiêu chuẩn</span>
                <span>FREE</span>
            </div>

            <div class="grand-total">
                <span>TỔNG CỘNG</span>
                <span>@Model.TotalAmount.ToString("N0") VNĐ</span>
            </div>
        </div>

        <div class="shipping-preview mt-4 pt-4 border-top">
            <span class="text-muted small fw-800 text-uppercase d-block mb-2"><i class="fa-solid fa-truck-fast me-1"></i> Địa chỉ nhận hàng</span>
            <div class="fw-700 fs-5 mb-1">@Model.Address.RecipientName</div>
            <div class="text-muted small fw-600">@Model.Address.Phone</div>
            <div class="text-muted small">@Model.Address.Ward, @Model.Address.District, @Model.Address.Province</div>
        </div>
    </div>

    <div class="btn-group-lux">
        <a href="@Url.Action("Index", "Orders")" class="btn-lux btn-lux-primary">
            <i class="fa-solid fa-clipboard-list"></i> Xem đơn hàng của tôi
        </a>
        <a href="/" class="btn-lux btn-lux-outline">
            <i class="fa-solid fa-house"></i> Tiếp tục mua sắm
        </a>
    </div>

    <div class="mt-5 text-muted small fw-500">
        Bạn sẽ sớm nhận được email xác nhận chi tiết. Nếu có thắc mắc, vui lòng liên hệ <span class="fw-700 text-primary">hotline @@ddhstore.</span>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script>
    // Trigger confetti on load
    $(document).ready(function() {
        var duration = 2 * 1000;
        var animationEnd = Date.now() + duration;
        var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

        function randomInRange(min, max) {
            return Math.random() * (max - min) + min;
        }

        var interval = setInterval(function() {
            var timeLeft = animationEnd - Date.now();

            if (timeLeft <= 0) {
                return clearInterval(interval);
            }

            var particleCount = 50 * (timeLeft / duration);
            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
        }, 250);
    });
</script>
