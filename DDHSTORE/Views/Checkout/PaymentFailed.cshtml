@model DDHSTORE.Models.Order

@{
    ViewData["Title"] = "Thanh toán thất bại";
}

<!-- Use Inter for high-end typography -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --brand-error: #ef4444;
        --brand-main: #0f172a;
        --bg-body: #f8fafc;
        --card-bg: #ffffff;
        --text-headline: #0f172a;
        --text-muted: #64748b;
        --radius-xl: 30px;
    }

    body {
        background-color: var(--bg-body);
        font-family: 'Inter', sans-serif;
        color: var(--text-headline);
        -webkit-font-smoothing: antialiased;
    }

    .failed-wrapper {
        max-width: 650px;
        margin: 80px auto;
        padding: 0 20px;
        text-align: center;
    }

    /* Animated X Mark */
    .error-circle {
        width: 120px;
        height: 120px;
        background: var(--brand-error);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 40px;
        box-shadow: 0 20px 40px -10px rgba(239, 68, 68, 0.4);
        animation: scaleIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        0% { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .error-circle i {
        color: #fff;
        font-size: 50px;
        animation: shake 0.6s 0.3s ease-in-out;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-8px); }
        40%, 80% { transform: translateX(8px); }
    }

    .failed-title {
        font-weight: 900;
        font-size: 2.2rem;
        letter-spacing: -0.04em;
        margin-bottom: 15px;
        color: var(--brand-error);
    }

    .failed-msg {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-bottom: 40px;
        font-weight: 500;
        line-height: 1.7;
    }

    /* Info Card */
    .info-card {
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        padding: 35px 40px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
        border: 1px solid #fecaca;
        text-align: left;
        margin-bottom: 40px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        font-weight: 600;
        border-bottom: 1px solid #f1f5f9;
    }

    .info-row:last-child { border-bottom: none; }

    .info-label { color: var(--text-muted); }
    .info-value { font-weight: 700; }
    .info-value.error-text { color: var(--brand-error); }

    /* Action Buttons */
    .btn-group-lux {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-lux {
        padding: 18px 35px;
        border-radius: 18px;
        font-weight: 800;
        font-size: 1rem;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-lux-primary {
        background: var(--brand-main);
        color: #fff;
        box-shadow: 0 10px 20px -5px rgba(15, 23, 42, 0.3);
    }

    .btn-lux-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -10px rgba(15, 23, 42, 0.4);
        color: #fff;
    }

    .btn-lux-retry {
        background: linear-gradient(135deg, #005baa, #003f7d);
        color: #fff;
        box-shadow: 0 10px 20px -5px rgba(0, 91, 170, 0.3);
    }

    .btn-lux-retry:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -10px rgba(0, 91, 170, 0.4);
        color: #fff;
    }

    .btn-lux-outline {
        background: transparent;
        border: 2px solid #e2e8f0;
        color: var(--brand-main);
    }

    .btn-lux-outline:hover {
        background: #f1f5f9;
        transform: translateY(-3px);
    }

    /* Decorative */
    .bg-circle {
        position: fixed;
        z-index: -1;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(239, 68, 68, 0.05) 0%, rgba(255,255,255,0) 70%);
    }

    .circle-1 { width: 600px; height: 600px; top: -200px; right: -100px; }
    .circle-2 { width: 400px; height: 400px; bottom: -100px; left: -50px; }
</style>

<div class="bg-circle circle-1"></div>
<div class="bg-circle circle-2"></div>

<div class="failed-wrapper">
    <div class="error-circle">
        <i class="fa-solid fa-xmark"></i>
    </div>

    <h1 class="failed-title">Thanh toán không thành công</h1>
    <p class="failed-msg">
        @(ViewBag.ErrorMessage ?? "Giao dịch thanh toán qua VNPay đã bị hủy hoặc gặp lỗi. Đơn hàng của bạn chưa được xử lý. Vui lòng thử lại hoặc chọn phương thức thanh toán khác.")
    </p>

    @if (Model != null)
    {
        <div class="info-card">
            <div class="info-row">
                <span class="info-label">Mã đơn hàng</span>
                <span class="info-value">#ORD-@Model.OrderId</span>
            </div>
            <div class="info-row">
                <span class="info-label">Tổng tiền</span>
                <span class="info-value">@Model.TotalAmount.ToString("N0") VNĐ</span>
            </div>
            <div class="info-row">
                <span class="info-label">Trạng thái</span>
                <span class="info-value error-text">
                    <i class="fa-solid fa-circle-xmark me-1"></i> ĐÃ HỦY
                </span>
            </div>
        </div>
    }

    <div class="btn-group-lux">
        <a href="@Url.Action("Index", "Checkout")" class="btn-lux btn-lux-retry">
            <i class="fa-solid fa-rotate-right"></i> Thử lại
        </a>
        <a href="@Url.Action("Index", "Orders")" class="btn-lux btn-lux-primary">
            <i class="fa-solid fa-clipboard-list"></i> Đơn hàng của tôi
        </a>
        <a href="/" class="btn-lux btn-lux-outline">
            <i class="fa-solid fa-house"></i> Về trang chủ
        </a>
    </div>

    <div class="mt-5 text-muted small fw-500">
        Nếu bạn đã bị trừ tiền nhưng đơn hàng không thành công, vui lòng liên hệ <span class="fw-700 text-primary">hotline @@ddhstore</span> để được hỗ trợ.
    </div>
</div>
