@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="ddh-page-title mb-3">
            <div>
                <h2>@ViewData["Title"]</h2>
                <div class="ddh-subtitle">Chào mừng bạn quay lại DDHSTORE</div>
            </div>
        </div>

        <div class="ddh-card p-4">
            @* Hiển thị thông báo đăng ký thành công *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
            }

            @* Hiển thị tất cả lỗi ModelState *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm">
                    <ul class="mb-0">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label for="username" class="form-label fw-bold">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                        <input name="username" id="username" class="form-control" placeholder="Nhập username" autocomplete="username" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-bold">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                        <input name="password" id="password" type="password" class="form-control" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                    </div>
                </div>

                <button type="submit" class="btn btn-ddh w-100">
                    <i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập
                </button>

                <div class="mt-3">
                    <a asp-action="LoginGoogle" class="btn btn-soft w-100">
                        <i class="fab fa-google me-1"></i> Đăng nhập bằng Google
                    </a>
                </div>

                <div class="text-center mt-3">
                    <span class="text-muted">Chưa có tài khoản?</span>
                    <a asp-action="Register" class="fw-bold text-decoration-none" style="color: var(--ddh-brand);">Đăng ký</a>
                </div>
            </form>
        </div>
    </div>
</div>