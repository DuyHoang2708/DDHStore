@{
    ViewData["Title"] = "Đổi mật khẩu";
    var userId = Context.Session.GetInt32("UserId"); // Lấy UserId từ session

    // Nếu chưa login thì redirect về login
    if (userId == null)
    {
        <text>
            <script>
                    window.location.href = '/Account/Login';
            </script>
        </text>
    }
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="ddh-page-title mb-3">
            <div>
                <h2>Đổi mật khẩu</h2>
                <div class="ddh-subtitle">Tạo mật khẩu mạnh để bảo vệ tài khoản</div>
            </div>
            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>

        <div class="ddh-card p-4">
            @* Hiển thị thông báo thành công *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
            }

            <form asp-action="ChangePassword" method="post">
                <input type="hidden" name="userId" value="@userId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu cũ</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-key"></i></span>
                        <input type="password" name="oldPassword" class="form-control" required autocomplete="current-password" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu mới</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="newPassword" class="form-control" required autocomplete="new-password" />
                    </div>
                    <div class="form-text">
                        Ít nhất 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.
                    </div>
                </div>

                <button type="submit" class="btn btn-ddh w-100">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Lưu mật khẩu mới
                </button>
            </form>

            @* Hiển thị lỗi từ ModelState *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm mt-3">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }
        </div>
    </div>
</div>