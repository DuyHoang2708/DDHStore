@model DDHSTORE.Models.EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa thông tin";
}

@section Styles {
    <style>
        .panel {
            border-radius: 16px;
            border: 1px solid rgba(0,0,0,0.06);
        }
        .section-title {
            font-weight: 800;
            letter-spacing: .2px;
        }
    </style>
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-4">
    <div>
        <div class="h3 mb-0 fw-bold">Chỉnh sửa thông tin</div>
        <div class="text-muted">Cập nhật email, số điện thoại và địa chỉ nhận hàng.</div>
    </div>
    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<hr class="my-4" />

<form asp-action="EditProfile" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-lg-5">
            <div class="card shadow-sm panel">
                <div class="card-body p-4">
                    <div class="section-title h5 mb-3">
                        <i class="fa-solid fa-user-pen me-2 text-danger"></i>Thông tin liên hệ
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập</label>
                        <input class="form-control" value="@Model.Username" disabled />
                        <input asp-for="Username" type="hidden" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="vd: abc@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" placeholder="vd: 0987654321" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                        <div class="form-text">Định dạng: 9–15 chữ số, có thể có dấu + ở đầu.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm panel">
                <div class="card-body p-4">
                    <div class="section-title h5 mb-3">
                        <i class="fa-solid fa-location-dot me-2 text-danger"></i>Địa chỉ nhận hàng (mặc định)
                    </div>

                    <div class="mb-3">
                        <label asp-for="RecipientName" class="form-label">Người nhận</label>
                        <input asp-for="RecipientName" class="form-control" />
                        <span asp-validation-for="RecipientName" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Province" class="form-label">Tỉnh/Thành phố</label>
                            <select id="ProvinceDropdown" asp-for="Province" class="form-select">
                                <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                @foreach (var province in ViewBag.Provinces as List<DDHSTORE.Controllers.AccountController.ProvinceApiModel>)
                                {
                                    <option value="@province.name" data-code="@province.code">@province.name</option>
                                }
                            </select>
                            <span asp-validation-for="Province" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="District" class="form-label">Quận/Huyện</label>
                            <select id="DistrictDropdown" asp-for="District" class="form-select">
                                <option value="">-- Chọn Quận/Huyện --</option>
                            </select>
                            <span asp-validation-for="District" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Ward" class="form-label">Phường/Xã</label>
                            <select id="WardDropdown" asp-for="Ward" class="form-select">
                                <option value="">-- Chọn Phường/Xã --</option>
                            </select>
                            <span asp-validation-for="Ward" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Detail" class="form-label">Địa chỉ chi tiết</label>
                        <input asp-for="Detail" class="form-control" placeholder="Số nhà, tên đường..." />
                        <span asp-validation-for="Detail" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="text-danger">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>

                <div class="d-flex gap-2">
                    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary">Hủy</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            var provinceDropdown = document.getElementById('ProvinceDropdown');
            var districtDropdown = document.getElementById('DistrictDropdown');
            var wardDropdown = document.getElementById('WardDropdown');

            if (!provinceDropdown || !districtDropdown || !wardDropdown) return;

            function resetDistricts() {
                districtDropdown.innerHTML = '<option value="">-- Chọn Quận/Huyện --</option>';
            }

            function resetWards() {
                wardDropdown.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
            }

            function loadDistricts(provinceCode, selectedDistrictName) {
                resetDistricts();
                resetWards();
                if (!provinceCode) return Promise.resolve();

                return fetch('https://provinces.open-api.vn/api/p/' + provinceCode + '?depth=2')
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (!data || !data.districts) return;
                        data.districts.forEach(function (district) {
                            var opt = document.createElement('option');
                            opt.value = district.name;
                            opt.setAttribute('data-code', district.code);
                            opt.textContent = district.name;
                            districtDropdown.appendChild(opt);
                        });

                        if (selectedDistrictName) {
                            districtDropdown.value = selectedDistrictName;
                        }
                    });
            }

            function loadWards(districtCode, selectedWardName) {
                resetWards();
                if (!districtCode) return Promise.resolve();

                return fetch('https://provinces.open-api.vn/api/d/' + districtCode + '?depth=2')
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (!data || !data.wards) return;
                        data.wards.forEach(function (ward) {
                            var opt = document.createElement('option');
                            opt.value = ward.name;
                            opt.textContent = ward.name;
                            wardDropdown.appendChild(opt);
                        });

                        if (selectedWardName) {
                            wardDropdown.value = selectedWardName;
                        }
                    });
            }

            // change handlers
            provinceDropdown.addEventListener('change', function () {
                var selectedOption = this.options[this.selectedIndex];
                var provinceCode = selectedOption ? selectedOption.getAttribute('data-code') : null;
                loadDistricts(provinceCode, null).catch(function () { });
            });

            districtDropdown.addEventListener('change', function () {
                var selectedOption = this.options[this.selectedIndex];
                var districtCode = selectedOption ? selectedOption.getAttribute('data-code') : null;
                loadWards(districtCode, null).catch(function () { });
            });

            // initial: auto-select based on existing model values
            var initialProvince = provinceDropdown.value;
            var initialDistrict = districtDropdown.getAttribute('data-selected') || '@(Model.District ?? "")';
            var initialWard = wardDropdown.getAttribute('data-selected') || '@(Model.Ward ?? "")';

            // Ensure province dropdown has correct selected option in DOM
            if (initialProvince) {
                provinceDropdown.value = initialProvince;
            }

            var selectedProvinceOption = provinceDropdown.options[provinceDropdown.selectedIndex];
            var provinceCodeInit = selectedProvinceOption ? selectedProvinceOption.getAttribute('data-code') : null;

            loadDistricts(provinceCodeInit, initialDistrict)
                .then(function () {
                    var selectedDistrictOption = districtDropdown.options[districtDropdown.selectedIndex];
                    var districtCodeInit = selectedDistrictOption ? selectedDistrictOption.getAttribute('data-code') : null;
                    return loadWards(districtCodeInit, initialWard);
                })
                .catch(function () { });
        })();
    </script>
}

