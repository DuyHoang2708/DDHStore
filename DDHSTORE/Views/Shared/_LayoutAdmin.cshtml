@{
    Layout = null;
    var userName = Context.Session.GetString("Phone") ?? "Admin";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - DDH Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        body {
            background: #f8fafc;
            font-family: 'Inter', "Segoe UI", Roboto, Helvetica, sans-serif;
            color: #334155;
        }

        /* Modern Premium Sidebar */
        .sidebar-admin {
            min-height: 100vh;
            background: #0f172a; /* Slate 900 */
            color: #94a3b8; /* Slate 400 */
            border-right: 1px solid #1e293b;
            box-shadow: 4px 0 24px rgba(15, 23, 42, 0.15);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            width: 280px;
            transition: all 0.3s ease;
        }

        .sidebar-admin .sidebar-header {
            font-size: 1.25rem;
            font-weight: 800;
            padding: 2rem 1.5rem 1.5rem;
            text-align: center;
            color: #ffffff;
            letter-spacing: -0.02em;
            border-bottom: 1px solid #1e293b;
            margin-bottom: 1rem;
        }

        .sidebar-admin .sidebar-header div {
            font-size: 0.85rem;
            font-weight: 500;
            color: #64748b;
            margin-top: 0.25rem;
        }

        .sidebar-admin .sidebar-header i {
            color: #3b82f6; /* Blue 500 */
        }

        .sidebar-admin .nav-link {
            color: #94a3b8;
            border-radius: 12px;
            margin: 0.25rem 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.25s ease;
            padding: 0.85rem 1.25rem;
            display: flex;
            align-items: center;
        }

        .sidebar-admin .nav-link:hover {
            color: #ffffff;
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateX(4px);
        }

        .sidebar-admin .nav-link.active {
            color: #ffffff;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            transform: translateX(0);
        }

        .sidebar-admin .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }

        .sidebar-admin .user-info {
            padding: 1.5rem 1rem;
            margin-top: auto;
            border-top: 1px solid #1e293b;
            background: #0b1120;
        }

        .sidebar-admin .user-info .fa-user-circle {
            font-size: 2.2rem;
            margin-right: 12px;
            color: #3b82f6;
        }

        .sidebar-admin .user-info span {
            color: #f1f5f9;
            font-weight: 600;
        }

        .sidebar-admin .logout-btn {
            margin-top: 1rem;
            width: 100%;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 10px;
            font-weight: 600;
            padding: 0.6rem;
            transition: all 0.2s;
        }

        .sidebar-admin .logout-btn:hover {
            background: #ef4444;
            color: #ffffff;
            border-color: #ef4444;
        }

        footer {
            background: transparent;
            color: #64748b;
        }

        main.content {
            background: transparent;
            padding: 2.5rem;
            margin-left: 280px;
            min-height: calc(100vh - 60px);
        }

        /* Mobile Adjustments */
        @@media (max-width: 991.98px) {
            .sidebar-admin {
                position: fixed;
                left: -280px;
            }

            .sidebar-admin.show {
                left: 0;
            }

            main.content {
                margin-left: 0;
                padding: 1.5rem;
            }

            footer {
                margin-left: 0 !important;
            }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Sidebar -->
        <nav class="sidebar-admin d-flex flex-column">
            <div class="sidebar-header">
                <i class="fas fa-shield-alt me-2"></i> DDHSTORE Admin
                <div>Quản trị hệ thống</div>
            </div>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "AdminDashboard")" class="nav-link @(currentController == "AdminDashboard" ? "active" : "")">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "AdminUsers")" class="nav-link @(currentController == "AdminUsers" ? "active" : "")">
                        <i class="fas fa-users"></i> Quản lý người dùng
                    </a>
                </li>

                <li class="nav-item">
                    <a href="@Url.Action("Index", "AdminOrders")" class="nav-link @(currentController == "AdminOrders" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i> Quản lý đơn hàng
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-controller="Products"
                           asp-action="Index"
                           asp-area=""
                           class="nav-link @(currentController == "Products" ? "active" : "")">
                        <i class="fas fa-boxes"></i> Quản lý sản phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Category"
                           asp-action="Index"
                           asp-area=""
                           class="nav-link @(currentController == "Category" ? "active" : "")">
                        <i class="fas fa-boxes"></i> Quản lý danh mục
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Brand"
                           asp-action="Index"
                           asp-area=""
                           class="nav-link @(currentController == "Brand" ? "active" : "")">
                        <i class="fas fa-boxes"></i> Quản lý thương hiệu
                    </a>
                </li>

            </ul>
            <div class="user-info mt-auto d-flex align-items-center flex-column">
                <div class="d-flex align-items-center mb-2">
                    <i class="fas fa-user-circle"></i>
                    <span class="ms-2">@userName</span>
                </div>
                @using (Html.BeginForm("Logout", "Account", new { area = "" }, FormMethod.Post))
                {
                    <button type="submit" class="btn btn-danger btn-sm logout-btn">
                        <i class="fas fa-sign-out-alt me-1"></i> Đăng xuất
                    </button>
                }
            </div>
        </nav>

        <!-- Main content -->
        <main class="content">
            <!-- Mobile menu button -->
            <button class="btn btn-primary d-md-none mb-3" id="sidebarToggle" style="position: fixed; top: 10px; left: 10px; z-index: 1001;">
                <i class="fas fa-bars"></i>
            </button>
            @RenderBody()
        </main>

        <footer class="text-center py-3 small text-muted" style="margin-left: 300px;">
            &copy; @DateTime.Now.Year DDHSTORE Admin. All rights reserved.
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle sidebar on mobile
        document.getElementById('sidebarToggle').addEventListener('click', function() {
        const sidebar = document.querySelector('.sidebar-admin');
        sidebar.classList.toggle('show');
        });
        
        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(e) {
        const sidebar = document.querySelector('.sidebar-admin');
        const toggleBtn = document.getElementById('sidebarToggle');
            
        if (window.innerWidth <= 768) {
        if (!sidebar.contains(e.target) && !toggleBtn.contains(e.target)) {
        sidebar.classList.remove('show');
        }
        }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
