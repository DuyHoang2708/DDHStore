@model IEnumerable<DDHSTORE.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark">
            <i class="fa-solid fa-bag-shopping text-primary me-2"></i>Lịch sử mua hàng
        </h2>
        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Tiếp tục mua sắm
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="ps-4 py-3">Mã đơn</th>
                            <th class="py-3">Ngày đặt</th>
                            <th class="py-3 text-end">Tổng tiền</th>
                            <th class="py-3 text-center">Trạng thái</th>
                            <th class="py-3 text-center">Thanh toán</th>
                            <th class="pe-4 py-3 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">#@item.OrderId</td>
                                    <td>
                                        <div class="text-dark fw-medium">@item.OrderDate.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.OrderDate.ToString("HH:mm")</div>
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @item.TotalAmount.ToString("N0") <span class="small">₫</span>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var statusClass = item.Status?.ToUpper() switch
                                            {
                                                "PENDING" => "bg-warning-subtle text-warning border-warning",
                                                "PROCESSING" => "bg-info-subtle text-info border-info",
                                                "SHIPPING" => "bg-primary-subtle text-primary border-primary",
                                                "COMPLETED" => "bg-success-subtle text-success border-success",
                                                "CANCELLED" => "bg-danger-subtle text-danger border-danger",
                                                _ => "bg-secondary-subtle text-secondary border-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass border rounded-pill px-3 py-2 fw-semibold" style="font-size: 0.75rem; min-width: 100px;">
                                            @(item.Status ?? "N/A")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Payment != null)
                                        {
                                            var payClass = item.Payment.Status?.ToUpper() == "SUCCESS" ? "text-success" : "text-muted";
                                            <div class="small @payClass fw-bold">
                                                <i class="fa-solid fa-credit-card me-1"></i>@item.Payment.Status
                                            </div>
                                            <div class="small text-muted font-monospace" style="font-size: 0.7rem;">@item.Payment.Method</div>
                                        }
                                        else
                                        {
                                            <span class="small text-muted italic">N/A</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Details" asp-route-id="@item.OrderId" 
                                               class="btn btn-white btn-sm border rounded-pill px-3 hover-shadow-sm">
                                                <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                            </a>

                                            @if (item.Status?.ToUpper() == "PENDING")
                                            {
                                                <button type="button" 
                                                        class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#cancelModal-@item.OrderId">
                                                    <i class="fa-solid fa-xmark me-1"></i>Hủy
                                                </button>

                                                <div class="modal fade text-start" id="cancelModal-@item.OrderId" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog modal-dialog-centered modal-sm">
                                                        <div class="modal-content border-0 shadow-lg rounded-4">
                                                            <div class="modal-body text-center p-4">
                                                                 <div class="mb-3 text-danger">
                                                                     <i class="fa-solid fa-circle-exclamation fa-3.5x"></i>
                                                                 </div>
                                                                 <h5 class="fw-bold text-dark">Hủy đơn hàng?</h5>
                                                                 <p class="small text-muted mb-4">Bạn chắc chắn muốn hủy đơn hàng <strong>#@item.OrderId</strong>? Hành động này không thể hoàn tác.</p>
                                                                 
                                                                 <form asp-action="CancelOrder" asp-route-id="@item.OrderId" method="post">
                                                                     @Html.AntiForgeryToken()
                                                                     <div class="d-grid gap-2">
                                                                         <button type="submit" class="btn btn-danger rounded-pill fw-bold py-2">Xác nhận hủy</button>
                                                                         <button type="button" class="btn btn-light rounded-pill fw-medium py-2" data-bs-dismiss="modal">Quay lại</button>
                                                                     </div>
                                                                 </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="py-4">
                                        <i class="fa-solid fa-box-open fa-3x text-muted mb-3 opacity-50"></i>
                                        <h5 class="text-secondary fw-bold">Bạn chưa có đơn hàng nào</h5>
                                        <p class="text-muted small mb-4">Khám phá các sản phẩm tuyệt vời của chúng tôi ngay!</p>
                                        <a href="/" class="btn btn-primary rounded-pill px-5 shadow">Mua sắm ngay</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f9;
    }
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }
    .btn-white {
        background-color: #fff;
        color: #444;
        transition: all 0.2s ease-in-out;
    }
    .btn-white:hover {
        background-color: #fff;
        border-color: #adb5bd;
        color: #000;
        transform: translateY(-1px);
    }
    .hover-shadow-sm:hover {
        box-shadow: 0 .25rem .5rem rgba(0,0,0,.05);
    }
    .badge {
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .fa-3.5x { font-size: 3.5rem; }
    
    /* Hiệu ứng mượt cho Modal */
    .modal.fade .modal-dialog {
        transition: transform 0.2s ease-out;
        transform: scale(0.9);
    }
    .modal.show .modal-dialog {
        transform: scale(1);
    }

    /* Định nghĩa lại màu sắc cho trạng thái nhẹ hơn */
    .bg-warning-subtle { background-color: #fff9e6 !important; }
    .bg-success-subtle { background-color: #e6ffed !important; }
    .bg-danger-subtle { background-color: #fff5f5 !important; }
    .bg-info-subtle { background-color: #e6f7ff !important; }
    .bg-primary-subtle { background-color: #f0f5ff !important; }
</style>
