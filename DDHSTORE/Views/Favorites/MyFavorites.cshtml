@model List<DDHSTORE.Models.Favorite>

@{
    ViewData["Title"] = "Yêu thích";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #f5f7fb;
    }

    .fav-container {
        padding: 40px 0;
    }

    .fav-title {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 30px;
        color: #2c3e50;
    }

    .product-card {
        border-radius: 16px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
        position: relative;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

    .product-img {
        height: 200px;
        object-fit: contain;
        padding: 15px;
    }

    .fav-heart {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 38px;
        height: 38px;
        background: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        box-shadow: 0 3px 8px rgba(0,0,0,0.2);
        transition: 0.2s;
    }

        .fav-heart:hover {
            transform: scale(1.1);
        }

        .fav-heart i {
            color: #e74c3c;
            font-size: 18px;
        }

    .product-name {
        font-weight: 700;
        font-size: 16px;
        height: 45px;
        overflow: hidden;
    }

    .price {
        color: #e74c3c;
        font-weight: 800;
        font-size: 18px;
    }

    .btn-remove {
        background: #e74c3c;
        border: none;
        color: white;
        border-radius: 8px;
        padding: 8px;
        font-size: 13px;
        transition: 0.2s;
    }

        .btn-remove:hover {
            background: #c0392b;
        }

    .btn-cart {
        background: #3498db;
        border: none;
        color: white;
        border-radius: 8px;
        padding: 8px;
        font-size: 13px;
    }

        .btn-cart:hover {
            background: #2980b9;
        }

    /* EMPTY */
    .empty-box {
        text-align: center;
        padding: 80px 0;
        color: #7f8c8d;
    }

    /* TOAST */
    .toast-box {
        position: fixed;
        top: 20px;
        right: 20px;
        background: #2ecc71;
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        display: none;
        z-index: 9999;
    }

    .toast-error {
        background: #e74c3c;
    }
</style>

<div class="container fav-container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fav-title">❤️ Sản phẩm yêu thích (@Model.Count)</h2>

        @if (Model.Any())
        {
            <button class="btn btn-danger" onclick="removeAll()">
                🗑 Xóa tất cả
            </button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-box">
            <h4>Chưa có sản phẩm yêu thích</h4>
            <a href="/" class="btn btn-primary">Mua ngay</a>
        </div>
    }
    else
    {
        <div class="row" id="favList">
            @foreach (var item in Model)
            {
                var p = item.Product;

                <div class="col-md-3 mb-4 fav-item" id="fav-@p.ProductId">
                    <div class="product-card">

                        <div class="fav-heart" onclick="removeOne(@p.ProductId)">
                            <i class="fa-solid fa-heart"></i>
                        </div>

                        <img src="@(p.ImageUrl ?? "https://via.placeholder.com/300")"
                             class="w-100 product-img" />

                        <div class="p-3">

                            <div class="product-name">@p.ProductName</div>

                            <div class="price mb-2">
                                @p.Price.ToString("N0") đ
                            </div>

                             <div class="d-flex gap-2">
                                @if (p.Quantity > 0)
                                {
                                    <button type="button" class="btn btn-soft w-100" onclick="addToCartAjax(@p.ProductId)">
                                        <i class="fa-solid fa-cart-shopping me-1"></i> Thêm vào giỏ
                                    </button>
                                }
                                else
                                {
                                    <a href="https://zalo.me/0xXXXXXXXX" target="_blank" class="btn btn-warning w-100" style="font-size: 12px; font-weight: 700;">
                                        <i class="fa-solid fa-phone me-1"></i> Liên hệ/Hết hàng
                                    </a>
                                }

                                <button class="btn-remove w-50"
                                        onclick="removeOne(@p.ProductId)">
                                    ❌ Xóa
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

<div id="toast" class="toast-box"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function toast(msg, error = false) {
    var t = $("#toast");
    t.text(msg);

    if (error) t.addClass("toast-error");
    else t.removeClass("toast-error");

    t.fadeIn().delay(2000).fadeOut();
    }

    // 🔥 XÓA 1
    function removeOne(productId) {
    $.post("/Favorites/Remove", { productId: productId }, function () {

    $("#fav-" + productId).fadeOut(300, function () {
    $(this).remove();

    toast("Đã xóa khỏi yêu thích");

    if ($(".fav-item").length === 0) {
    location.reload();
    }
    });

    }).fail(() => toast("Lỗi xóa", true));
    }

    // 🔥 XÓA ALL
    function removeAll() {
    if (!confirm("Xóa toàn bộ yêu thích?")) return;

    $.post("/Favorites/RemoveAll", function (res) {

    if (res.success) {
    toast("Đã xóa tất cả");
    setTimeout(() => location.reload(), 800);
    } else {
    toast("Lỗi", true);
    }

    });
    }

    function addToCart(productId) {

    $.ajax({
    url: '/Cart/AddAjax',
    type: 'POST',
    data: { id: productId },

    success: function (res) {

    if (res.success) {
    showToast("🛒 " + res.message);

    // update số lượng giỏ
    $(".cart-count").text(res.cartCount);
    }
    else {
    showToast("❌ " + res.message, "error");
    }
    },

    error: function () {
    showToast("❌ Lỗi server", "error");
    }
    });
    }   
</script>